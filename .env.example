APP_NAME=Smart Assistant Backend
ENVIRONMENT=local
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://agentic_user:agentic_pass@localhost:5432/agentic_ai
TEST_DATABASE_URL=postgresql+psycopg://smart_user:smart_password@localhost:5432/smart_assistant_test
REDIS_URL=redis://localhost:6379/0

OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LLM_MODEL=llama3.1
DEFAULT_EMBEDDING_MODEL=nomic-embed-text

EMAIL_PROVIDER=console
EMAIL_FROM_NAME=Expernetic Careers
EMAIL_FROM_ADDRESS=no-reply@expernetic.com

SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=your_username
SMTP_PASSWORD=your_password
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=30